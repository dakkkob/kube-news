# Copy to terraform.tfvars and fill in your values
# terraform.tfvars is in .gitignore — never committed

prefect_api_url = "https://api.prefect.cloud/api/accounts/YOUR_ACCOUNT/workspaces/YOUR_WORKSPACE"
prefect_api_key = "pnu_your_key_here"
github_token    = "ghp_your_token_here"

# Phase 2 — Processing
hf_api_token   = "hf_your_token_here"
qdrant_url     = "https://your-cluster.cloud.qdrant.io:6333"
qdrant_api_key = "your_qdrant_api_key_here"

# Phase 2 — MLflow on DagsHub
mlflow_tracking_uri      = "https://dagshub.com/your-user/kube-news.mlflow"
mlflow_tracking_username = "your-dagshub-username"
mlflow_tracking_password = "your-dagshub-token"

# Uncomment if you want GitHub Actions OIDC
# github_org = "your-github-username"
