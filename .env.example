# AWS
AWS_REGION=eu-west-1
S3_BUCKET=kube-news-raw
DYNAMODB_TABLE=kube-news

# GitHub (for higher rate limits: 5000 req/h vs 60 req/h)
GITHUB_TOKEN=ghp_your_token_here

# Prefect Cloud
PREFECT_API_URL=https://api.prefect.cloud/api/accounts/YOUR_ACCOUNT/workspaces/YOUR_WORKSPACE
PREFECT_API_KEY=pnu_your_key_here

# Qdrant Cloud (Phase 2)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_key_here

# MLflow / DagsHub (Phase 2)
MLFLOW_TRACKING_URI=https://dagshub.com/your_user/kube-news.mlflow
MLFLOW_TRACKING_USERNAME=your_user
MLFLOW_TRACKING_PASSWORD=your_dagshub_token

# OpenAI (Phase 3)
OPENAI_API_KEY=sk-your_key_here

# Slack (Phase 3)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# HuggingFace Inference API (Phase 2 - zero-shot classifier)
HF_API_TOKEN=hf_your_token_here
